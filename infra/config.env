# infra/config.env — shared config for all infra scripts
#
# Copy this file to infra/config.local.env and fill in your values.
# config.local.env is gitignored — never commit it.
#
# All scripts source this file automatically. A new developer only
# needs to edit this one file to get all scripts working.

# ── Required ──────────────────────────────────────────────────────────────────

# GCP project ID — find it at console.cloud.google.com or `gcloud projects list`
GCP_PROJECT_ID=""

# GitHub repo in owner/name format — used to scope Workload Identity Federation
# so only Actions from this repo can authenticate to GCP
GITHUB_REPO=""

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# GCP region for all resources
GCP_REGION="${GCP_REGION:-us-central1}"

# App name prefix — used for resource naming (bucket, SA names, service names)
# Change this only if running multiple AgentWatch deployments in the same project
APP_NAME="${APP_NAME:-agentwatch}"
